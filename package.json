{
  "name": "ccosming-plugins",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Claude Code plugin marketplace by ccosming.",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun scripts/build.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.6",
    "prettier": "^3.4.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
  }
}
